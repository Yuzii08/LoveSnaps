<?xml version="1.0" encoding="utf-8"?>
<!--
  Small LoveSnaps Widget Layout (2x1 / 4x1)
  Shows: streak flame + count, days counter
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_background_small"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:clickable="true"
    android:focusable="true">

    <!-- Streak section -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/widget_streak_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/widget_streak_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#5C5D6E" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="streak"
            android:textSize="10sp"
            android:textColor="#656677" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#20000000"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <!-- Days Together section -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💕"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/widget_days_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Day 0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#5C5D6E" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="together"
            android:textSize="10sp"
            android:textColor="#656677" />

    </LinearLayout>

</LinearLayout>
