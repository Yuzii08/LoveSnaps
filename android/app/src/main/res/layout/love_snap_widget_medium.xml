<?xml version="1.0" encoding="utf-8"?>
<!--
  Medium LoveSnaps Widget Layout (4x2)
  Shows: streak, days, distance, miss you button
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background_medium"
    android:padding="16dp">

    <!-- Top row: Streak + Days -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Streak -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_streak_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥"
                android:textSize="28sp"
                android:layout_marginEnd="8dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_streak_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 days"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#5C5D6E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="streak"
                    android:textSize="10sp"
                    android:textColor="#656677" />

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <FrameLayout
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#20000000"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <!-- Days Together -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💕 Together"
                android:textSize="10sp"
                android:textColor="#656677" />

            <TextView
                android:id="@+id/widget_days_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Day 0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#5C5D6E" />

        </LinearLayout>

    </LinearLayout>

    <!-- Divider line -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#18000000"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <!-- Bottom row: Distance + Miss You button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Distance -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Distance"
                android:textSize="10sp"
                android:textColor="#656677" />

            <TextView
                android:id="@+id/widget_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#5C5D6E" />

        </LinearLayout>

        <!-- Miss You button -->
        <TextView
            android:id="@+id/widget_miss_you_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💕 Miss You"
            android:background="@drawable/miss_you_button_bg"
            android:textColor="#915761"
            android:textSize="13sp"
            android:textStyle="bold"
            android:padding="10dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>
