rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isCoupleМember(coupleData) {
      return request.auth.uid in coupleData.memberIds;
    }

    // ── Users collection ─────────────────────────────────────────────────
    match /users/{uid} {
      // User can read/write only their own document
      allow read: if isAuthenticated() && isOwner(uid);
      allow create: if isAuthenticated() && isOwner(uid);
      allow update: if isAuthenticated() && isOwner(uid);
      allow delete: if false; // no deletes from client
    }

    // ── Couples collection ───────────────────────────────────────────────
    match /couples/{coupleId} {
      // Read: must be authenticated and either be a member or doc not yet fully paired
      allow read: if isAuthenticated() && (
        resource == null ||
        request.auth.uid in resource.data.memberIds
      );

      // Create: can only create if you are the first member
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberIds.size() == 1;

      // Update: must be an existing member
      // Special case: joining (adding second member) is allowed even if not yet a member
      allow update: if isAuthenticated() && (
        // Normal update by existing member
        request.auth.uid in resource.data.memberIds
        ||
        // Joining: adding yourself as second member
        (
          resource.data.memberIds.size() == 1
          && request.auth.uid in request.resource.data.memberIds
          && request.resource.data.memberIds.size() == 2
          // Ensure only memberIds changes (or a few safe fields)
        )
      );

      // Delete: not allowed from client
      allow delete: if false;
    }
  }
}
